{
  "private": true,
  "name": "remix-app-template",
  "description": "",
  "license": "",
  "scripts": {
    "postinstall": "npm run setup:worker",
    "setup:worker": "remix setup cloudflare-workers",
    "setup:local": "remix setup node",
    "build:css": "tailwindcss --output ./app/styles/tailwind.css --minify --postcss",
    "build:remix": "remix build",
    "build:worker": "esbuild --define:process.env.NODE_ENV=\\\"production\\\" --define:process.env.API_URL=API_URL --define:process.env.ACCESS_TOKEN=ACCESS_TOKEN --define:process.env.SESSION_SECRET=SESSION_SECRET --bundle --sourcemap --format=esm --outfile=dist/worker.mjs ./worker",
    "prebuild:worker": "npm run setup:worker",
    "build": "run-s codegen build:*",
    "predev": "npm run setup:local",
    "dev": "pm2-dev pm2.config.js",
    "dev:remix": "remix dev",
    "dev:css": "tailwindcss --output ./app/styles/tailwind.css --watch --postcss",
    "codegen": "graphql-codegen --require dotenv/config --config codegen.yml"
  },
  "dependencies": {
    "@cfpreview/pages-cli": "0.0.3",
    "@headlessui/react": "1.4.1",
    "@heroicons/react": "1.0.5",
    "@mcansh/fetcher": "0.2.2",
    "@remix-run/cloudflare-workers": "0.20.1",
    "@remix-run/node": "0.20.1",
    "@remix-run/react": "0.20.1",
    "date-fns": "2.25.0",
    "graphql": "16.0.0",
    "graphql-request": "3.6.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "react-router-dom": "6.0.0-beta.6",
    "remix": "0.20.1",
    "remix-utils": "1.0.2",
    "type-fest": "2.5.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "2.2.2",
    "@graphql-codegen/typescript": "2.3.0",
    "@graphql-codegen/typescript-graphql-request": "4.2.0",
    "@graphql-codegen/typescript-operations": "2.2.0",
    "@remix-run/dev": "0.20.1",
    "@tailwindcss/aspect-ratio": "0.3.0",
    "@tailwindcss/forms": "0.3.4",
    "@tailwindcss/typography": "0.4.1",
    "@types/react": "17.0.33",
    "@types/react-dom": "17.0.10",
    "autoprefixer": "10.4.0",
    "npm-run-all": "4.1.5",
    "pm2": "5.1.2",
    "postcss-100vh-fix": "1.0.2",
    "tailwindcss": "2.2.19",
    "typescript": "4.4.4"
  },
  "engines": {
    "node": ">=14"
  },
  "sideEffects": false
}
